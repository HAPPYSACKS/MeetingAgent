{
  "ConnectionStrings": {
    "MeetingAgent": ""
  },
  "MeetingAgent": {
    "Retention": {
      "TranscriptArtifactDays": 3,
      "RecapArtifactDays": 30,
      "MeetingMetadataDays": 180
    },
    "RetentionCleanup": {
      "Enabled": true,
      "IntervalMinutes": 1440
    }
  },
  "Sql": {
    "ServerName": "",
    "DatabaseName": "",
    "UseManagedIdentity": true,
    "CommandTimeoutSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
