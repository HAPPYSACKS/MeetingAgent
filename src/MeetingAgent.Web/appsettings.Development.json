{
  "DetailedErrors": true,
  "ConnectionStrings": {
    "MeetingAgent": "Server=(localdb)\\MSSQLLocalDB;Database=MeetingAgent;Trusted_Connection=True;MultipleActiveResultSets=True;TrustServerCertificate=True"
  },
  "MeetingAgent": {
    "Retention": {
      "TranscriptArtifactDays": 1,
      "RecapArtifactDays": 14,
      "MeetingMetadataDays": 30
    },
    "RetentionCleanup": {
      "Enabled": true,
      "IntervalMinutes": 1440
    }
  },
  "Sql": {
    "ServerName": "",
    "DatabaseName": "",
    "UseManagedIdentity": true,
    "CommandTimeoutSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
