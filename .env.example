MEETINGAGENT_TEAMS_BASE_URL=https://<your-dev-tunnel-host>
# Optional: set this to keep the Teams app package id stable across rebuilds.
# MEETINGAGENT_TEAMS_APP_ID=00000000-0000-0000-0000-000000000000

# Optional preview auth manifest metadata. Leave off for plain Teams package smoke testing.
# MEETINGAGENT_INCLUDE_PREVIEW_AUTH=false
# MEETINGAGENT_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Resource-specific Graph consent metadata is added only when running the package
# script directly with -IncludeRscPermissions.
